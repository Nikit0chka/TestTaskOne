<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:weighting="clr-namespace:TestTaskOne.ViewModels.Weighting"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TestTaskOne.Views.Weighting.ListWeightingView"
             x:DataType="weighting:ListWeightingViewModel">

    <Grid RowDefinitions="Auto, *">
        <StackPanel>
            <Button Content="Update" Command="{Binding LoadCommand}"
                    Margin="5" HorizontalAlignment="Left" />

            <Button Content="Create" Command="{Binding GotoCreateWeightingPageCommand}"
                    Margin="5" HorizontalAlignment="Left" />

            <Button Content="Export" Command="{Binding ExportToFileCommand}"
                    Margin="5" HorizontalAlignment="Left" />
        </StackPanel>

        <DataGrid x:Name="WeightingDataGrid" Grid.Row="1" ItemsSource="{Binding Weightings}"
                  AutoGenerateColumns="False" CanUserResizeColumns="True"
                  IsReadOnly="True" Margin="5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding WeightingId}" Width="auto" />
                <DataGridTextColumn Header="Car number" Binding="{Binding CarNumber}" Width="auto" />
                <DataGridTextColumn Header="Weight Gross" Binding="{Binding WeightingGross}" Width="auto" />
                <DataGridTextColumn Header="Weight net" Binding="{Binding WeightingNet}" Width="auto" />
                <DataGridTextColumn Header="Weight tare" Binding="{Binding WeightingTare}" Width="auto" />
                <DataGridTextColumn Header="Date gross" Binding="{Binding WeightingGrossDate}" Width="auto" />
                <DataGridTextColumn Header="Date tare" Binding="{Binding WeightingTareDate}" Width="auto" />

                <DataGridTemplateColumn Header="Actions" Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="5">
                                <Button Content="✏️"
                                        Command="{Binding $parent[DataGrid].((weighting:ListWeightingViewModel)DataContext).GotoEditWeightingPageCommand}"
                                        CommandParameter="{Binding WeightingId}"
                                        ToolTip.Tip="Edit" Padding="5" />
                                <Button Content="🗑️"
                                        Command="{Binding $parent[DataGrid].((weighting:ListWeightingViewModel)DataContext).DeleteCommand}"
                                        CommandParameter="{Binding WeightingId}"
                                        ToolTip.Tip="Delete" Padding="5" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>